# ============================================================
# SHARATH CONTENT ENGINE — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.
# ============================================================

# Supabase — get from your Supabase project dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Anthropic — get from console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# LinkedIn — get from LinkedIn Developer Portal (developer.linkedin.com)
LINKEDIN_CLIENT_ID=your-linkedin-client-id
LINKEDIN_CLIENT_SECRET=your-linkedin-client-secret
# Must match redirect URI registered in LinkedIn app settings
LINKEDIN_REDIRECT_URI=https://your-domain.com/auth/linkedin/callback

# App
NEXT_PUBLIC_APP_URL=https://your-domain.com
# Used for Vercel Cron job authentication (generate a random string)
CRON_SECRET=your-random-cron-secret-here

# ============================================================
# SETUP CHECKLIST
# ============================================================
# 1. Create Supabase project at supabase.com
# 2. Run supabase/migrations/001_initial_schema.sql in SQL Editor
# 3. Enable Email auth in Supabase Auth → Providers
# 4. Create Anthropic API key at console.anthropic.com
# 5. Create LinkedIn app at developer.linkedin.com
#    - Products: Sign In with LinkedIn + Share on LinkedIn
#    - Add redirect URI: https://your-domain.com/auth/linkedin/callback
# 6. Deploy to Vercel, add all env vars in Vercel dashboard
# 7. Add vercel.json cron configuration (see vercel.json)
